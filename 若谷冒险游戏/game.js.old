// 若谷冒险游戏 · 逻辑（独立版）
// 依赖 data.js 中的 HEROES / WEAPONS / LEVELS / starsForPower()

(function () {
  "use strict";

  // ---------- 存档 ----------
  const SAVE_KEY = "ruogu-adventure-v1"; // 与识字 App 的键完全隔离
  function loadSave() {
    try {
      const raw = localStorage.getItem(SAVE_KEY);
      if (raw) return JSON.parse(raw);
    } catch (e) {}
    return { cleared: [], equipped: "quan", stars: 0 };
  }
  function persist() {
    try { localStorage.setItem(SAVE_KEY, JSON.stringify(save)); } catch (e) {}
  }
  let save = loadSave();

  // ---------- 工具 ----------
  const $ = (sel, root) => (root || document).querySelector(sel);
  const app = $("#app");

  function isCleared(id) { return save.cleared.indexOf(id) !== -1; }
  // 关卡按顺序解锁：第 1 关永远可玩；后面的关需前一关通关
  function isUnlocked(idx) { return idx === 0 || isCleared(LEVELS[idx - 1].id); }
  function equippedWeapon() {
    return WEAPONS.find((w) => w.id === save.equipped) || WEAPONS[0];
  }
  function shuffle(arr) {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  // 角色图片，加载失败时回退到 emoji 占位（保证没抠图也能玩）
  function heroImg(src, cls, fallback) {
    return `<img class="${cls}" src="${src}" alt=""
      onerror="this.replaceWith(Object.assign(document.createElement('span'),{className:'${cls} emoji-fallback',textContent:'${fallback || "🐣"}'}))">`;
  }

  // ---------- 顶部状态条 ----------
  function topbar() {
    const w = equippedWeapon();
    return `
      <header class="topbar">
        <div class="brand">🗺️ 若谷大冒险</div>
        <div class="tb-right">
          <button class="weapon-chip" data-action="openWeapons">
            <span class="wc-emoji">${w.emoji}</span>
            <span class="wc-name">${w.name}</span>
            <span class="wc-power">武力 ${w.power}</span>
          </button>
          <div class="star-box">⭐ <span id="starCount">${save.stars}</span></div>
        </div>
      </header>`;
  }

  // ---------- 地图视图 ----------
  function renderMap() {
    const nodes = LEVELS.map((lv, idx) => {
      const cleared = isCleared(lv.id);
      const unlocked = isUnlocked(idx);
      const state = cleared ? "cleared" : unlocked ? "open" : "locked";
      const icon = cleared ? "✓" : unlocked ? lv.id : "🔒";
      return `
        <button class="node node-${state}" style="left:${lv.x}%; top:${lv.y}%"
                data-level="${lv.id}" ${unlocked ? "" : "disabled"}>
          <span class="node-dot">${icon}</span>
          <span class="node-name">${lv.name}</span>
        </button>`;
    }).join("");

    // 关卡之间连线（简单折线，SVG）
    let path = "";
    for (let i = 0; i < LEVELS.length - 1; i++) {
      const a = LEVELS[i], b = LEVELS[i + 1];
      path += `<line x1="${a.x}" y1="${a.y}" x2="${b.x}" y2="${b.y}"
        stroke="rgba(255,255,255,.55)" stroke-width="0.8"
        stroke-dasharray="2 2" stroke-linecap="round"/>`;
    }

    app.innerHTML = `
      ${topbar()}
      <section class="map-wrap">
        <div class="map-bg">
          <svg class="map-lines" viewBox="0 0 100 100" preserveAspectRatio="none">${path}</svg>
          ${nodes}
        </div>
        <p class="map-tip">点亮所有关卡，帮若谷侠闯到云顶宝殿！</p>
      </section>`;

    app.querySelectorAll(".node-open, .node-cleared").forEach((btn) => {
      btn.addEventListener("click", () => startBattle(Number(btn.dataset.level)));
    });
    $(".weapon-chip", app).addEventListener("click", openWeapons);
  }

  // ---------- 武器选择弹窗 ----------
  function openWeapons() {
    const list = WEAPONS.map((w) => {
      const active = w.id === save.equipped ? "wp-active" : "";
      return `
        <button class="wp-card ${active}" data-weapon="${w.id}">
          <span class="wp-emoji">${w.emoji}</span>
          <span class="wp-name">${w.name}</span>
          <span class="wp-power">武力值 ${w.power}</span>
          <span class="wp-desc">${w.desc}</span>
        </button>`;
    }).join("");
    const modal = document.createElement("div");
    modal.className = "modal-mask";
    modal.innerHTML = `
      <div class="modal">
        <h2>选一件兵器</h2>
        <div class="wp-grid">${list}</div>
        <button class="btn-ghost" data-action="closeModal">关闭</button>
      </div>`;
    document.body.appendChild(modal);
    modal.querySelectorAll(".wp-card").forEach((c) => {
      c.addEventListener("click", () => {
        save.equipped = c.dataset.weapon;
        persist();
        modal.remove();
        renderMap();
      });
    });
    modal.addEventListener("click", (e) => {
      if (e.target === modal || e.target.dataset.action === "closeModal") modal.remove();
    });
  }

  // ---------- 战斗视图（答题打怪）----------
  let battle = null;
  function startBattle(levelId) {
    const level = LEVELS.find((l) => l.id === levelId);
    battle = {
      level,
      qOrder: shuffle(level.questions.map((_, i) => i)),
      qi: 0,               // 当前第几题
      hp: level.hp,        // 怪兽血量
      hpMax: level.hp,
      earned: 0,           // 本关得星
    };
    renderBattle();
  }

  function renderBattle() {
    const { level, hp, hpMax } = battle;
    const qIndex = battle.qOrder[battle.qi];
    const q = level.questions[qIndex];
    const opts = shuffle(q.options);
    const w = equippedWeapon();
    const hearts = "❤️".repeat(hp) + "🖤".repeat(hpMax - hp);

    app.innerHTML = `
      ${topbar()}
      <section class="battle">
        <div class="battle-stage">
          <div class="fighter hero-side">
            ${heroImg(HEROES.player, "sprite hero-sprite", "🦸")}
            <div class="fighter-name">${HEROES.playerName} ${w.emoji}</div>
          </div>
          <div class="vs">⚔️</div>
          <div class="fighter monster-side">
            ${heroImg(level.monster, "sprite monster-sprite", "👾")}
            <div class="monster-hp">${hearts}</div>
            <div class="fighter-name">${level.monsterName}</div>
          </div>
        </div>

        <div class="quiz-card">
          <div class="level-tag">${level.name}${level.boss ? " · BOSS" : ""} · 第 ${battle.qi + 1}/${level.questions.length} 题</div>
          <div class="quiz-word">${q.word}</div>
          <div class="quiz-hint">选出正确的读音，打败怪兽！</div>
          <div class="opt-grid">
            ${opts.map((o) => `<button class="opt" data-pin="${o}">${o}</button>`).join("")}
          </div>
          <div class="quiz-feedback" id="qfb"></div>
        </div>
        <button class="btn-ghost" data-action="backMap">← 回地图</button>
      </section>`;

    const fb = $("#qfb", app);
    const heroSprite = $(".hero-sprite", app);
    const monsterSprite = $(".monster-sprite", app);

    app.querySelectorAll(".opt").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (battle.locked) return;
        const correct = btn.dataset.pin === q.pinyin;
        if (correct) {
          battle.locked = true;
          btn.classList.add("opt-right");
          heroSprite && heroSprite.classList.add("attack");
          const gained = starsForPower(w.power);
          battle.earned += gained;
          battle.hp -= 1;
          save.stars += gained;
          persist();
          $("#starCount", app) && ($("#starCount", app).textContent = save.stars);
          fb.className = "quiz-feedback ok";
          fb.textContent = `太棒了！${w.name}攻击！+${gained}⭐`;
          setTimeout(() => {
            if (battle.hp <= 0) { winLevel(); return; }
            battle.qi = (battle.qi + 1) % level.questions.length;
            battle.locked = false;
            renderBattle();
          }, 900);
        } else {
          btn.classList.add("opt-wrong");
          monsterSprite && monsterSprite.classList.add("attack");
          fb.className = "quiz-feedback bad";
          fb.textContent = `再想想～「${q.word}」读「${q.pinyin}」`;
        }
      });
    });
    $("[data-action='backMap']", app).addEventListener("click", renderMap);
  }

  function winLevel() {
    const { level, earned } = battle;
    if (!isCleared(level.id)) save.cleared.push(level.id);
    persist();
    const allDone = LEVELS.every((l) => isCleared(l.id));
    app.innerHTML = `
      ${topbar()}
      <section class="result">
        <div class="result-burst">🎉</div>
        <h2>${level.boss ? "通关啦！" : "闯关成功！"}</h2>
        <p class="result-line">打败了 <b>${level.monsterName}</b>，本关获得 <b>${earned}⭐</b></p>
        ${allDone
          ? `<p class="result-final">若谷侠闯完了整张地图，真是个大英雄！🏆</p>`
          : `<p class="result-line">下一关已经解锁，继续冒险吧！</p>`}
        <div class="result-actions">
          <button class="btn-primary" data-action="backMap">回地图</button>
        </div>
      </section>`;
    $("[data-action='backMap']", app).addEventListener("click", renderMap);
  }

  // ---------- 启动 ----------
  renderMap();
})();
