// ===== 武器 = 战斗力 =====
// power 越高，答对每题得星越多。第一版自带精简几件（阶段二换成真实 10 件神兵）。
const WEAPONS = [
  { id: "quan",   name: "拳头",   power: 0,  emoji: "👊", desc: "空手也能闯！每答对 +2 星" },
  { id: "qiankunquan", name: "乾坤圈", power: 60, emoji: "⭕", desc: "哪吒的宝物，每答对 +3 星" },
  { id: "jiuchidingpa", name: "九齿钉耙", power: 80, emoji: "🔱", desc: "猪八戒的神兵，每答对 +4 星" },
  { id: "jingubang", name: "金箍棒", power: 95, emoji: "🪄", desc: "孙悟空的定海神针，每答对 +5 星" },
];

// power → 每题得星（装备越强，得星越多）
function starsForPower(power) {
  if (power >= 95) return 5;
  if (power >= 80) return 4;
  if (power >= 60) return 3;
  return 2;
}

